<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BigFood OS v8.0 - Inter Affiliate Edition</title>
    <style>
        /* === TEMA BIGLINUX APEX === */
        :root { --bg-deep: #0a0b10; --glass-bg: rgba(15, 20, 30, 0.6); --glass-border: rgba(0, 243, 255, 0.15); --neon-cyan: #00f3ff; --neon-blue: #0077ff; --danger: #ff3b3b; --success: #00e676; --inter-orange: #ff7a00; --text-main: #f0f4f8; --warning: #ffb300; --wa-color: #25D366; --tg-color: #0088cc; }
        body { background-color: var(--bg-deep); background-image: radial-gradient(circle at top right, rgba(255, 122, 0, 0.05), transparent 40%), radial-gradient(circle at bottom left, rgba(0, 243, 255, 0.05), transparent 40%); color: var(--text-main); font-family: 'Segoe UI', system-ui, sans-serif; margin: 0; padding: 0; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
        
        /* TOAST NOTIFICATIONS */
        #toastContainer { position: fixed; bottom: 20px; right: 20px; z-index: 99999; display: flex; flex-direction: column; gap: 10px; }
        .toast { background: rgba(10, 15, 20, 0.95); backdrop-filter: blur(10px); border-left: 4px solid var(--neon-cyan); padding: 15px 20px; border-radius: 6px; box-shadow: 0 4px 20px rgba(0,0,0,0.5); color: white; font-weight: 500; font-size: 0.9rem; animation: slideIn 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) forwards; display: flex; align-items: center; justify-content: space-between; min-width: 250px; }
        .toast.success { border-color: var(--success); } .toast.error { border-color: var(--danger); } .toast.warning { border-color: var(--warning); } .toast.inter { border-color: var(--inter-orange); }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes fadeOut { to { opacity: 0; transform: translateY(-10px); } }

        /* LOGIN */
        #loginScreen { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #050608; display: flex; justify-content: center; align-items: center; z-index: 10000; }
        .login-box { background: var(--glass-bg); backdrop-filter: blur(20px); border: 1px solid rgba(255, 122, 0, 0.3); padding: 50px 40px; border-radius: 16px; text-align: center; width: 360px; box-shadow: 0 10px 50px rgba(255, 122, 0, 0.1); transition: transform 0.3s ease; }
        .login-box:hover { transform: translateY(-5px); }
        .login-box h2 { color: var(--inter-orange); margin: 0 0 5px 0; letter-spacing: 2px; font-weight: 700; text-transform: uppercase; }
        .login-box input { width: 100%; padding: 14px; margin-bottom: 20px; border-radius: 8px; border: 1px solid #333; background: rgba(0,0,0,0.6); color: white; box-sizing: border-box; font-size: 1rem; transition: border 0.3s; }
        .login-box input:focus { border-color: var(--inter-orange); outline: none; }

        /* SISTEMA */
        #mainApp { display: none; flex-direction: column; height: 100vh; padding: 20px; box-sizing: border-box; }
        .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--glass-border); padding-bottom: 15px; }
        .header h1 { margin: 0; color: var(--text-main); font-size: 1.6rem; font-weight: 600; letter-spacing: 1px; }
        .header h1 span { color: var(--inter-orange); font-weight: 800; }
        .user-info { text-align: right; font-size: 0.95rem; color: #aaa; } .user-info strong { color: var(--neon-cyan); font-size: 1.1rem; }
        
        .navbar { display: flex; gap: 12px; justify-content: center; margin-bottom: 25px; flex-wrap: wrap;}
        .btn-nav { background: rgba(0,0,0,0.4); border: 1px solid #333; color: #888; font-weight: 600; padding: 12px 24px; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; font-size: 0.95rem; }
        .btn-nav:hover { background: rgba(0, 243, 255, 0.1); color: var(--text-main); border-color: var(--neon-cyan); }
        .btn-nav.active { background: linear-gradient(135deg, rgba(255,122,0,0.2) 0%, rgba(0,243,255,0.2) 100%); border-color: var(--inter-orange); color: #fff; box-shadow: 0 0 20px rgba(255, 122, 0, 0.15); }

        .panel { background: var(--glass-bg); backdrop-filter: blur(15px); border: 1px solid var(--glass-border); border-radius: 16px; padding: 25px; flex: 1; display: none; overflow-y: auto; position: relative; box-shadow: inset 0 0 30px rgba(0,0,0,0.5); }
        .panel.active { display: block; animation: scaleIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes scaleIn { from { opacity: 0; transform: scale(0.98); } to { opacity: 1; transform: scale(1); } }

        .form-group { display: flex; gap: 15px; margin-bottom: 20px; align-items: flex-end; flex-wrap: wrap; } .form-group > div { flex: 1; min-width: 150px; }
        label { display: block; margin-bottom: 8px; font-size: 0.85rem; color: #bbb; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
        input, select, textarea { width: 100%; padding: 12px; border: 1px solid #444; border-radius: 8px; background: rgba(0,0,0,0.4); color: white; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; font-size: 1rem; transition: border 0.3s; }
        input:focus, select:focus, textarea:focus { border-color: var(--neon-cyan); outline: none; }
        
        button.btn-action { background: var(--neon-blue); color: white; border: none; padding: 12px 20px; border-radius: 8px; cursor: pointer; font-weight: 700; width: 100%; height: 45px; transition: all 0.2s ease; letter-spacing: 0.5px; }
        button.btn-action:hover { opacity: 0.9; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); } button.btn-action:active { transform: translateY(0); }
        button.btn-success { background: linear-gradient(135deg, #00b09b, #96c93d); color: #000; }
        button.btn-danger { background: linear-gradient(135deg, #ff416c, #ff4b2b); color: white; }
        button.btn-inter { background: linear-gradient(135deg, #ff7a00, #ff9900); color: white; }
        button.btn-logout { background: transparent; border: 1px solid var(--danger); color: var(--danger); margin-top: 8px; padding: 6px 15px; cursor: pointer; border-radius: 6px; font-weight: 600; font-size: 0.8rem; transition: 0.3s; }
        button.btn-logout:hover { background: var(--danger); color: white; }

        table { width: 100%; border-collapse: separate; border-spacing: 0 5px; margin-top: 10px; font-size: 0.95rem; }
        th { color: var(--neon-cyan); font-size: 0.8rem; text-transform: uppercase; padding: 10px; letter-spacing: 1px; border-bottom: 1px solid #333; }
        td { background: rgba(0,0,0,0.3); padding: 12px 10px; border-top: 1px solid transparent; border-bottom: 1px solid transparent; }
        tr td:first-child { border-radius: 8px 0 0 8px; border-left: 1px solid transparent; } tr td:last-child { border-radius: 0 8px 8px 0; border-right: 1px solid transparent; }
        tr:hover td { background: rgba(255, 122, 0, 0.05); border-color: rgba(255, 122, 0, 0.1); }

        .qr-box { background: #fff; color: #000; padding: 15px; text-align: center; word-break: break-all; font-family: monospace; border-radius: 8px; font-weight: bold; font-size: 0.85rem; box-shadow: inset 0 0 10px rgba(0,0,0,0.2); }
        .dashboard-cards { display: flex; gap: 20px; margin-bottom: 25px; flex-wrap: wrap; }
        .card { background: linear-gradient(145deg, rgba(0,0,0,0.6) 0%, rgba(15,20,30,0.8) 100%); border: 1px solid #222; padding: 25px; border-radius: 12px; flex: 1; min-width: 200px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.2); transition: 0.3s; }
        .card:hover { border-color: var(--inter-orange); transform: translateY(-3px); }
        .card h3 { margin: 0 0 10px 0; color: #888; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }
        .card p { margin: 0; font-size: 2.2rem; color: var(--success); font-weight: 800; text-shadow: 0 0 15px rgba(0, 230, 118, 0.3); }

        .log-box { background: #050505; color: var(--neon-cyan); font-family: 'Courier New', Courier, monospace; padding: 15px; height: 150px; overflow-y: auto; border: 1px solid #222; font-size: 0.85rem; border-radius: 8px; box-shadow: inset 0 0 15px #000; }

        /* LOCK OVERLAY E RBAC */
        #pdvLockOverlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(5, 6, 8, 0.98); z-index: 100; display: flex; flex-direction: column; justify-content: center; align-items: center; border-radius: 16px; text-align: center; }
        #pdvLockOverlay h2 { color: var(--danger); font-size: 2rem; margin-bottom: 10px; }
        body:not(.is-admin) .admin-only { display: none !important; }

        /* MODAL CUSTOMIZADO */
        #customModal { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index: 100000; display: none; justify-content:center; align-items:center; backdrop-filter: blur(5px); }
        .modal-content { background: var(--glass-bg); border: 1px solid var(--neon-cyan); border-radius: 12px; padding: 30px; width: 400px; text-align: center; }
        .modal-content h3 { color: var(--neon-cyan); margin-top: 0; }

        /* IMPRESSÃO TÉRMICA (80mm) */
        .print-area { display: none; }
        @media print { 
            body { background: #fff; color: #000; padding: 0; margin: 0; width: 80mm; font-family: monospace; font-size: 11px; height: auto; overflow: visible; display: block; } 
            #mainApp, #loginScreen, #toastContainer, #customModal { display: none !important; } 
            .print-area { display: block; width: 100%; padding: 2mm; box-sizing: border-box; } 
            h1.print-title { font-size: 14px; text-align: center; margin: 0 0 5px 0; } 
            .item-linha { display: flex; justify-content: space-between; margin-bottom: 3px; } 
            .total-linha { font-weight: bold; font-size: 13px; text-align: right; border-top: 1px dashed #000; padding-top: 5px; margin-top: 5px; } 
            .fiscal-box { border-top: 1px dashed #000; border-bottom: 1px dashed #000; padding: 5px 0; margin: 5px 0; text-align: center; font-size: 10px; }
            .pix-print { text-align: center; margin-top: 5px; border: 1px solid #000; padding: 5px; } 
            .qr-print-img { width: 120px; height: 120px; margin: 5px auto; display: block; }
        }

        /* Animação do Scanner Inter */
        .scanning { animation: pulseBorder 1.5s infinite; }
        @keyframes pulseBorder { 0% { border-color: #333; box-shadow: 0 0 0 0 rgba(255, 122, 0, 0.4); } 70% { border-color: var(--inter-orange); box-shadow: 0 0 0 10px rgba(255, 122, 0, 0); } 100% { border-color: #333; box-shadow: 0 0 0 0 rgba(255, 122, 0, 0); } }
    </style>
</head>
<body>

    <!-- SISTEMA DE NOTIFICAÇÕES -->
    <div id="toastContainer"></div>

    <!-- MODAL CUSTOMIZADO -->
    <div id="customModal">
        <div class="modal-content">
            <h3>CUPOM FISCAL ELETRÔNICO</h3>
            <p style="color: #aaa; font-size: 0.9rem; margin-bottom: 20px;">Deseja incluir CPF/CNPJ na Nota?<br>(Deixe em branco para Consumidor Final)</p>
            <input type="text" id="modalInputDoc" placeholder="Apenas números..." style="text-align: center; letter-spacing: 2px; font-size: 1.2rem;">
            <div style="display: flex; gap: 10px; margin-top: 20px;">
                <button class="btn-action" style="background: #333;" onclick="SysModal.close(null)">Cancelar</button>
                <button class="btn-action btn-success" onclick="SysModal.confirm()">Confirmar & Emitir</button>
            </div>
        </div>
    </div>

    <!-- 1. LOGIN BLINDADO -->
    <div id="loginScreen">
        <div class="login-box">
            <h2>BigFood OS</h2>
            <p style="color: #666; font-size: 0.85rem; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 1px;">Powered by Banco Inter</p>
            <input type="text" id="loginUser" placeholder="Credencial de Operador">
            <input type="password" id="loginPass" placeholder="Código de Segurança">
            <button class="btn-action btn-inter" onclick="SysAuth.login()" style="font-size: 1.1rem; color: #fff;">AUTENTICAR COMANDO</button>
            <p id="dbInitStatus" style="color: #555; font-size: 0.75rem; margin-top: 15px;">Estabelecendo conexão segura com Safenode...</p>
        </div>
    </div>

    <!-- 2. SISTEMA PRINCIPAL -->
    <div id="mainApp">
        <div class="header">
            <div>
                <h1>BigFood <span>OS v8.0</span></h1>
                <small style="color: #888; font-weight: 500;">Gateway Integrado: <strong style="color: var(--inter-orange);">Banco Inter Corporativo</strong></small>
            </div>
            <div class="user-info">
                Bem-vindo de volta,<br>
                <strong id="loggedUserName">---</strong><br>
                <button class="btn-logout" onclick="SysAuth.logout()">Encerrar Sessão</button>
            </div>
        </div>

        <div class="navbar no-print">
            <button class="btn-nav active" onclick="SysUI.switchTab('tab-pdv', this)">1. Caixa Rápido</button>
            <button class="btn-nav" onclick="SysUI.switchTab('tab-clientes', this)">2. Gestão de Clientes</button>
            <button class="btn-nav" onclick="SysUI.switchTab('tab-estoque', this)">3. Controle de Estoque</button>
            <button class="btn-nav admin-only" onclick="SysUI.switchTab('tab-financeiro', this)">4. DRE Financeiro</button>
            <button class="btn-nav admin-only" onclick="SysUI.switchTab('tab-config', this)">5. Setup Militar</button>
        </div>

        <!-- PAINEL PDV -->
        <div id="tab-pdv" class="panel active">
            <div id="pdvLockOverlay">
                <h2>⚠️ SISTEMA INTERROMPIDO</h2>
                <p style="color: #ccc; margin-bottom: 25px;">Operação suspensa por segurança. Solicite a liberação ao Administrador.</p>
                <div style="width: 350px;">
                    <input type="text" id="opDocInput" placeholder="ID da Loja (CNPJ)">
                    <input type="password" id="opKeyInput" placeholder="Serial de Desbloqueio">
                    <button class="btn-action btn-success" onclick="SysSecurity.validateLicense()">RESTAURAR OPERAÇÃO</button>
                </div>
            </div>

            <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                <div style="flex: 2; min-width: 350px;">
                    <div class="form-group" style="background: rgba(0, 0, 0, 0.3); padding: 15px; border-radius: 8px; border-left: 3px solid var(--inter-orange);">
                        <div style="flex: 1;"><label style="color: var(--inter-orange);">Vincular Cliente (Para NF e Zap):</label><select id="pdvClienteSelect"><option value="0">Cliente Balcão (Avulso)</option></select></div>
                    </div>
                    <div class="form-group">
                        <div style="flex: 2;"><label>Selecione o Produto:</label><select id="pdvProdutoSelect"></select></div>
                        <div style="flex: 0.3;"><label>Qtd:</label><input type="number" id="pdvQtd" value="1" min="1" style="text-align: center;"></div>
                        <div style="flex: 0.5;"><button class="btn-action" onclick="SysPDV.addItem()">Incluir Item</button></div>
                    </div>
                    
                    <div style="background: rgba(0,0,0,0.2); border-radius: 8px; padding: 10px; min-height: 180px;">
                        <table id="pdvCartTable"><thead><tr><th>Item</th><th>Qtd</th><th>Subtotal</th><th style="text-align:center;">Remover</th></tr></thead><tbody></tbody></table>
                    </div>
                    
                    <div style="margin-top: 20px; display: flex; justify-content: space-between; align-items: center; background: rgba(0, 230, 118, 0.05); padding: 15px; border-radius: 8px; border: 1px solid rgba(0, 230, 118, 0.2);">
                        <div style="flex: 1;"><label>Logística (Motoboy):</label><select id="pdvMotoboy" onchange="SysPDV.updateTotal()"><option value="0">Retirada no Local (R$ 0,00)</option></select></div>
                        <h2 style="text-align: right; color: var(--success); margin: 0 0 0 20px; font-size: 2.5rem;">R$ <span id="pdvTotal">0.00</span></h2>
                    </div>
                </div>
                
                <div id="paymentBox" style="flex: 1; min-width: 300px; background: rgba(0,0,0,0.3); padding: 25px; border-radius: 12px; border: 1px solid #333; transition: 0.3s;">
                    <h3 style="margin-top:0; color: #fff; border-bottom: 1px solid #333; padding-bottom: 10px; display: flex; justify-content: space-between;">Fechamento <span style="color:var(--inter-orange);">Inter</span></h3>
                    
                    <button class="btn-action btn-inter" style="margin-bottom: 15px;" onclick="SysPDV.generatePix()">1. Gerar Código PIX</button>
                    
                    <div style="text-align: center; margin-bottom: 15px;"><img id="pixQrImage" style="display:none; margin: 0 auto; border-radius: 8px; border: 3px solid var(--inter-orange);" width="160" height="160"></div>
                    <div id="pixPayload" class="qr-box">Aguardando gatilho...</div>
                    
                    <!-- BOTÃO DE AFILIADO (MARKETING) -->
                    <button id="btnAffiliate" class="btn-action" style="display:none; margin-top: 15px; background: rgba(37, 211, 102, 0.1); color: var(--wa-color); border: 1px solid var(--wa-color); font-size: 0.85rem;" onclick="SysPDV.sendInterInvite()">O cliente não tem PIX? Envie seu link do Inter!</button>

                    <button id="btnSync" class="btn-action" style="margin-top: 25px; height: 55px; font-size: 1.1rem; background: #333; color: #888;" onclick="SysPDV.finalizeOrder()" disabled>2. CONFIRMAR RECEBIMENTO</button>
                    <p id="syncStatus" style="font-size: 0.8rem; color: var(--warning); text-align: center; margin-top: 15px; font-weight: bold;"></p>
                </div>
            </div>
        </div>

        <!-- PAINEL CLIENTES -->
        <div id="tab-clientes" class="panel">
            <div class="form-group" style="background: rgba(0,0,0,0.4); padding: 20px; border-radius: 12px; border: 1px solid #222;">
                <input type="hidden" id="cliEditId">
                <div><label>Nome Completo do Cliente</label><input type="text" id="cliNome"></div>
                <div><label>CPF/CNPJ (Fiscal)</label><input type="text" id="cliDoc" placeholder="Apenas números"></div>
                <div><label>WhatsApp Móvel</label><input type="text" id="cliFone" placeholder="DDD + Número"></div>
                <div style="flex: 100%; margin-top: 5px;"><label>Endereço de Entrega</label><input type="text" id="cliEnd"></div>
                <div style="flex: 0.5; margin-top: 15px;"><button class="btn-action btn-success" id="btnSalvarCli" onclick="SysClientes.save()">Gravar Cliente na Base</button></div>
                <div style="flex: 0.5; margin-top: 15px;"><button class="btn-action" style="background: #333;" onclick="SysClientes.clearForm()">Limpar Campos</button></div>
            </div>
            <table id="clientesTable"><thead><tr><th>ID</th><th>Nome</th><th>Documento</th><th>WhatsApp</th><th>Endereço</th><th style="text-align: center;">Ações</th></tr></thead><tbody></tbody></table>
        </div>

        <!-- PAINEL ESTOQUE -->
        <div id="tab-estoque" class="panel">
            <div class="form-group" style="background: rgba(0,0,0,0.4); padding: 20px; border-radius: 12px; border: 1px solid #222;">
                <input type="hidden" id="estEditId">
                <div><label>Nome do Item / Lanche</label><input type="text" id="estNome"></div>
                <div><label>Preço de Venda (R$)</label><input type="number" id="estPreco" step="0.01"></div>
                <div><label>Quantidade Física</label><input type="number" id="estQtd"></div>
                <div style="flex: 0.5;"><button class="btn-action btn-success" id="btnSalvarEstoque" onclick="SysEstoque.saveProduct()">Proteger Estoque</button></div>
                <div style="flex: 0.5;"><button class="btn-action" style="background: #333;" onclick="SysEstoque.clearForm()">Limpar</button></div>
            </div>
            <table id="estoqueTable"><thead><tr><th>Cód.</th><th>Descrição do Produto</th><th>Estoque</th><th>Valor Unit.</th><th>Saúde do Item</th><th style="text-align: center;">Manutenção</th></tr></thead><tbody></tbody></table>
        </div>

        <!-- PAINEL FINANCEIRO -->
        <div id="tab-financeiro" class="panel admin-only">
            <h2 style="color: var(--text-main); margin-top:0;">DRE & Balanço de Caixa</h2>
            <div class="dashboard-cards">
                <div class="card"><h3>Receita Bruta (Inter)</h3><p>R$ <span id="finTotalVendas">0.00</span></p></div>
                <div class="card"><h3>Volume de Operações</h3><p style="color: var(--neon-blue);"><span id="finTotalPedidos">0</span></p></div>
                <div class="card"><h3>Custo Logístico (Payout)</h3><p style="color: var(--warning);">R$ <span id="finPayout">0.00</span></p></div>
            </div>
            
            <div style="display: flex; gap: 20px; margin-bottom: 20px;">
                <div style="flex: 1; background: rgba(0, 243, 255, 0.05); border: 1px solid rgba(0, 243, 255, 0.2); padding: 20px; border-radius: 12px;">
                    <h3 style="color: var(--neon-cyan); margin-top: 0;">📤 Integração Contábil Automática</h3>
                    <div class="form-group" style="margin-bottom:0;">
                        <div style="flex: 2;"><label>E-mail Corporativo Contabilidade</label><input type="email" id="cfgEmailContador" placeholder="contabilidade@gmail.com"></div>
                        <div style="flex: 1;"><label>&nbsp;</label><button class="btn-action btn-success" onclick="SysFiscal.sendAccountingReport()">Disparar Fechamento</button></div>
                    </div>
                </div>
            </div>
            
            <h3 style="color: #fff; font-size: 1rem;">Auditoria do Sistema (Logs)</h3>
            <div id="sysLogBox" class="log-box"></div>
            <div style="margin-top: 25px; text-align: right;"><button class="btn-action btn-danger" style="width: auto; background: transparent; border: 1px solid var(--danger);" onclick="SysConfig.resetDatabase()">⚠️ FORÇAR FORMATAÇÃO DO BANCO LOCAL (WIPE)</button></div>
        </div>

        <!-- PAINEL CONFIGURAÇÕES MASTER -->
        <div id="tab-config" class="panel admin-only">
            <h2 style="color: var(--text-main); margin-top:0;">Central de Comando Master</h2>
            
            <div style="display: flex; gap: 25px; flex-wrap: wrap;">
                <div style="flex: 1; min-width: 350px;">
                    <!-- ADMIN KEYGEN -->
                    <div style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 20px; border-radius: 12px; margin-bottom: 20px;">
                        <h3 style="color: var(--neon-cyan); margin-top: 0; display: flex; align-items: center; gap:10px;"><span>🔑</span> Fábrica de Licenças (Keygen)</h3>
                        <div class="form-group"><div style="flex: 2;"><input type="text" id="genDocInput" placeholder="CPF/CNPJ do Contratante"></div><div style="flex: 1;"><button class="btn-action" style="background:#444;" onclick="SysSecurity.generateKey()">Processar Hash</button></div></div>
                        <input type="text" id="generatedKey" readonly style="background: #111; color: var(--success); font-weight: 800; text-align: center; letter-spacing: 3px; border-color: var(--success);">
                    </div>
                    
                    <!-- ADMIN LOCK -->
                    <div style="background: rgba(255, 59, 59, 0.05); border: 1px solid rgba(255, 59, 59, 0.2); padding: 20px; border-radius: 12px; margin-bottom: 20px;">
                        <h3 style="color: var(--danger); margin-top: 0;">🛑 Kill Switch Operacional</h3>
                        <div style="display: flex; gap: 15px;"><button class="btn-action" style="background: transparent; border: 1px solid var(--success); color: var(--success);" onclick="SysSecurity.forceUnlock()">🟢 Autorizar Vendas</button><button class="btn-action btn-danger" onclick="SysSecurity.forceLock()">🔴 Suspender Operação</button></div>
                    </div>

                    <!-- EXPORT FISCAL -->
                    <div style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 20px; border-radius: 12px;">
                        <h3 style="color: #fff; margin-top: 0;">Motor Fiscal (Sebrae / Guarulhos)</h3>
                        <div class="form-group"><div><label>Ambiente Tributário</label><select id="cfgAmbiente"><option value="Homologacao">Homologação (Simulação Segura)</option><option value="Producao">Produção Efetiva (SEFAZ)</option></select></div></div>
                        <label>Extrato XML/JSON Blindado (Última Venda)</label><textarea id="xmlOutputBox" rows="3" readonly style="font-size: 0.75rem; color: #888;"></textarea>
                        <button class="btn-action" style="margin-top: 15px; background: #333;" onclick="SysFiscal.exportSebrae()">Baixar Lote Físico (.TXT)</button>
                    </div>
                </div>

                <div style="flex: 1; min-width: 350px;">
                    <!-- GATEWAY EXCLUSIVO INTER -->
                    <div style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 20px; border-radius: 12px; margin-bottom: 20px;">
                        <h3 style="color: var(--inter-orange); margin-top: 0;">Banco Inter Corporativo (Exclusivo)</h3>
                        <div class="form-group">
                            <div><label>Sua Chave PIX (Inter)</label><input type="text" id="cfgPixKey" placeholder="CNPJ, Celular, Email"></div>
                        </div>
                        <div class="form-group" style="background: rgba(255, 122, 0, 0.1); padding: 15px; border-radius: 8px; border: 1px dashed var(--inter-orange);">
                            <div>
                                <label style="color: var(--inter-orange);">Seu Link de Indicação (Afiliado Inter)</label>
                                <input type="text" id="cfgInterRef" placeholder="https://bancointer.com.br/convite/..." style="border-color: var(--inter-orange);">
                                <small style="color: #ccc; display: block; margin-top: 5px;">Gere receita enviando este link no PDV para clientes que não tem PIX.</small>
                            </div>
                        </div>
                        <div class="form-group" style="margin-top: 15px;">
                            <div><label>Fator de Entrega Base (R$)</label><input type="number" id="cfgTaxa" step="0.50"></div>
                            <div><label>Servidor Safenode (Polling Webhook)</label><select id="cfgDdns"><option value="servidoroncaparda.ddns.com.br">Onça Parda (C# Webhook)</option><option value="shayrainfor.ddns.com.br">Shayra (C# Webhook)</option></select></div>
                        </div>
                        <button class="btn-action btn-success" onclick="SysConfig.saveParams()">Gravar Alterações Estruturais</button>
                    </div>
                    
                    <!-- GESTÃO DE EQUIPE -->
                    <div style="background: rgba(0,0,0,0.4); border: 1px solid #333; padding: 20px; border-radius: 12px;">
                        <h3 style="color: #fff; margin-top: 0;">Gestão de Recursos Humanos</h3>
                        <div style="display: flex; gap: 15px; margin-bottom: 15px;"><button class="btn-action" style="background: #222;" onclick="SysConfig.addUser()">+ Novo Operador</button><button class="btn-action" style="background: #222;" onclick="SysConfig.addMotoboy()">+ Cadastrar Motoboy</button></div>
                        <div style="max-height: 150px; overflow-y: auto; margin-bottom: 10px;"><table id="tblUsers" style="margin-top:0;"><thead><tr><th>Operador Logístico</th><th style="text-align:right;">Permissões</th></tr></thead><tbody></tbody></table></div>
                        <div style="max-height: 150px; overflow-y: auto;"><table id="tblMotoboys" style="margin-top:0;"><thead><tr><th>Frota / Entregadores</th><th style="text-align:right;">Permissões</th></tr></thead><tbody></tbody></table></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- AREA DE IMPRESSÃO TÉRMICA -->
    <div id="printReceipt" class="print-area"></div>

    <script>
        // === TOASTS (UX) ===
        const SysToast = { show: (msg, type = 'success') => { const container = document.getElementById('toastContainer'); const toast = document.createElement('div'); toast.className = `toast ${type}`; let icon = '✅'; if(type === 'error') icon = '❌'; if(type === 'warning') icon = '⚠️'; if(type === 'inter') icon = '🏦'; toast.innerHTML = `<span>${icon} &nbsp; ${msg}</span>`; container.appendChild(toast); setTimeout(() => { toast.style.animation = 'fadeOut 0.3s forwards'; setTimeout(() => toast.remove(), 300); }, 3000); } };

        // === MODAL CUSTOMIZADO ===
        const SysModal = { resolveRef: null, open: (msg, defaultValue) => { return new Promise((resolve) => { SysModal.resolveRef = resolve; document.getElementById('customModal').style.display = 'flex'; const inp = document.getElementById('modalInputDoc'); inp.value = defaultValue || ''; inp.focus(); }); }, close: (val) => { document.getElementById('customModal').style.display = 'none'; if(SysModal.resolveRef) SysModal.resolveRef(val); }, confirm: () => { SysModal.close(document.getElementById('modalInputDoc').value); } };

        // === MOTOR INDEXED-DB ===
        const SysDB = {
            db: null, cache: { Products: [], Users: [], Motoboys: [], Customers: [], Config: {}, Sales: [], Logs: [], License: 'locked', SyncQueue: [] },
            initIDB: () => { return new Promise((resolve, reject) => { const req = indexedDB.open("BigFood_OS_Database", 5); req.onupgradeneeded = (e) => { let db = e.target.result; if(!db.objectStoreNames.contains('DataStore')) db.createObjectStore('DataStore'); if(!db.objectStoreNames.contains('SyncQueue')) db.createObjectStore('SyncQueue', { keyPath: 'id', autoIncrement: true }); }; req.onsuccess = async (e) => { SysDB.db = e.target.result; await SysDB.loadToCache(); resolve(); }; req.onerror = () => reject(); }); },
            loadToCache: () => { return new Promise((resolve) => { const req = SysDB.db.transaction('DataStore', 'readonly').objectStore('DataStore').getAllKeys(); req.onsuccess = () => { const keys = req.result; if(keys.length === 0) { SysDB.seedDefaults(); resolve(); } else { let loaded = 0; keys.forEach(key => { const getReq = SysDB.db.transaction('DataStore', 'readonly').objectStore('DataStore').get(key); getReq.onsuccess = () => { SysDB.cache[key] = getReq.result; loaded++; if(loaded === keys.length) resolve(); }; }); } }; }); },
            seedDefaults: () => { SysDB.cache.Users = [{ id: 1, user: 'leandro', pass: 'Julia380l#', role: 'ADMIN' }, { id: 2, user: 'operador', pass: '1234', role: 'OPERADOR' }]; SysDB.cache.Products = [{ id: 1, name: 'Burger Artesanal', price: 29.90, stock: 100 }, { id: 2, name: 'Refrigerante Cola', price: 8.50, stock: 50 }]; SysDB.cache.Motoboys = [{ id: 1, name: 'Falcão (Express)' }]; SysDB.cache.Customers = [{ id: 1, name: 'Cliente Elite', doc: '59365037000166', phone: '11999999999', address: 'Guarulhos, Centro' }]; SysDB.cache.Config = { pixKey: '', ddns: 'servidoroncaparda.ddns.com.br', taxaEntrega: 6.00, emailContador: '', interRefLink: '' }; SysDB.cache.License = 'locked'; ['Users', 'Products', 'Motoboys', 'Customers', 'Config', 'License', 'Sales', 'Logs'].forEach(k => SysDB.persist(k)); },
            persist: (key) => { if(!SysDB.db) return; SysDB.db.transaction('DataStore', 'readwrite').objectStore('DataStore').put(SysDB.cache[key], key); },
            get: (key) => SysDB.cache[key] || [], set: (key, data) => { SysDB.cache[key] = data; SysDB.persist(key); },
            addToSyncQueue: (payload) => { SysDB.db.transaction('SyncQueue', 'readwrite').objectStore('SyncQueue').add({ payload: payload, timestamp: Date.now() }); SysSync.processQueue(); }
        };

        const SysSync = {
            isProcessing: false, startWorker: () => { setInterval(SysSync.processQueue, 30000); },
            processQueue: async () => { if(SysSync.isProcessing) return; SysSync.isProcessing = true; const req = SysDB.db.transaction('SyncQueue', 'readonly').objectStore('SyncQueue').getAll(); req.onsuccess = async () => { const items = req.result; if(items.length === 0) { SysSync.isProcessing = false; return; } const config = SysDB.get('Config'); const apiUrl = `https://${config.ddns}:54388/api/vendas/sincronizar`; for(let item of items) { try { const res = await fetch(apiUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(item.payload) }); if(res.ok) { SysDB.db.transaction('SyncQueue', 'readwrite').objectStore('SyncQueue').delete(item.id); } else break; } catch (e) { break; } } SysSync.isProcessing = false; }; }
        };

        const SysLog = { add: (msg) => { let logs = SysDB.get('Logs'); logs.unshift(`[${new Date().toLocaleTimeString()}] ${msg}`); if(logs.length > 50) logs.pop(); SysDB.set('Logs', logs); SysLog.render(); }, render: () => { const box = document.getElementById('sysLogBox'); if(box) box.innerHTML = SysDB.get('Logs').join('<br>'); } };

        const SysFiscal = {
            checkAccountingDates: () => { const today = new Date().getDate(); if (today === 15 || today === 27) SysToast.show(`Aviso: Rotina contábil de dia ${today} requerida.`, "warning"); },
            sendAccountingReport: () => { const cfg = SysDB.get('Config'), email = document.getElementById('cfgEmailContador').value || cfg.emailContador; if(!email) return SysToast.show("E-mail não definido.", "error"); cfg.emailContador = email; SysDB.set('Config', cfg); const sales = SysDB.get('Sales'); let total = 0; sales.forEach(s => total += s.t); const relatorio = `RELATORIO BIGFOOD\nVendas: ${sales.length}\nBruto: R$ ${total.toFixed(2)}\nData: ${new Date().toLocaleString()}`; SysToast.show("Cliente de E-mail acionado.", "success"); window.location.href = `mailto:${email}?subject=Fechamento Fiscal PDV&body=${encodeURIComponent(relatorio)}`; },
            gerarChaveAcesso: () => { let chave = "352606"; for(let i=0; i<38; i++) chave += Math.floor(Math.random() * 10).toString(); return chave; },
            generateNfcePayload: (cartItems, total, cliente, chaveAcesso) => { const payload = { ambiente: document.getElementById('cfgAmbiente').value || "Homologacao", chave_acesso: chaveAcesso, valor_total: total, cliente: cliente ? cliente.doc : "Consumidor Final", itens: cartItems.map(i => ({ descricao: i.name, quantidade: i.cartQtd, valor_unitario: i.price })) }; const xmlBox = document.getElementById('xmlOutputBox'); if(xmlBox) xmlBox.value = JSON.stringify(payload, null, 2); return payload; },
            exportSebrae: () => { const data = document.getElementById('xmlOutputBox').value; if(!data) return SysToast.show("Sem dados para exportar.", "warning"); const blob = new Blob([data], { type: 'text/plain' }), url = window.URL.createObjectURL(blob), a = document.createElement('a'); a.href = url; a.download = `LOTE_FISCAL_${Date.now()}.txt`; a.click(); window.URL.revokeObjectURL(url); SysToast.show("Arquivo gerado.", "success"); }
        };

        const SysClientes = {
            render: () => { const tbody = document.querySelector('#clientesTable tbody'); tbody.innerHTML = ''; SysDB.get('Customers').forEach(c => { tbody.innerHTML += `<tr><td>#${c.id}</td><td><strong>${c.name}</strong></td><td style="color:#aaa">${c.doc}</td><td>${c.phone}</td><td>${c.address}</td><td style="text-align:right;"><button class="btn-action btn-warning" style="padding:6px; width:auto;" onclick="SysClientes.edit(${c.id})">✏️</button> <button class="btn-action btn-danger" style="padding:6px; width:auto;" onclick="SysClientes.delete(${c.id})">❌</button></td></tr>`; }); },
            save: () => { const id = document.getElementById('cliEditId').value, n = document.getElementById('cliNome').value, d = document.getElementById('cliDoc').value, f = document.getElementById('cliFone').value, e = document.getElementById('cliEnd').value; if(!n) return SysToast.show('Nome obrigatório.', 'error'); let cli = SysDB.get('Customers'); if(id) { const index = cli.findIndex(x => x.id == id); if(index > -1) cli[index] = { id: parseInt(id), name: n, doc: d, phone: f, address: e }; } else cli.push({ id: Date.now(), name: n, doc: d, phone: f, address: e }); SysDB.set('Customers', cli); SysClientes.clearForm(); SysClientes.render(); SysPDV.loadDependencies(); SysToast.show("Dados do cliente atualizados.", "success"); },
            edit: (id) => { const c = SysDB.get('Customers').find(x => x.id === id); if(c) { document.getElementById('cliEditId').value = c.id; document.getElementById('cliNome').value = c.name; document.getElementById('cliDoc').value = c.doc; document.getElementById('cliFone').value = c.phone; document.getElementById('cliEnd').value = c.address; document.getElementById('btnSalvarCli').innerText = "Atualizar Base"; } },
            delete: (id) => { SysDB.set('Customers', SysDB.get('Customers').filter(x => x.id !== id)); SysClientes.render(); SysPDV.loadDependencies(); SysToast.show("Cliente removido.", "success"); },
            clearForm: () => { document.getElementById('cliEditId').value = ''; document.getElementById('cliNome').value = ''; document.getElementById('cliDoc').value = ''; document.getElementById('cliFone').value = ''; document.getElementById('cliEnd').value = ''; document.getElementById('btnSalvarCli').innerText = "Gravar Cliente na Base"; }
        };

        const SysEstoque = {
            render: () => { const tbody = document.querySelector('#estoqueTable tbody'); tbody.innerHTML = ''; SysDB.get('Products').forEach(p => { tbody.innerHTML += `<tr><td>#${p.id}</td><td><strong>${p.name}</strong></td><td style="color:var(--neon-cyan); font-weight:bold;">${p.stock}</td><td>R$ ${p.price.toFixed(2)}</td><td>${p.stock <= 10 ? '<span style="color:var(--danger); font-weight:bold;">Baixo</span>' : '<span style="color:var(--success)">Saudável</span>'}</td><td style="text-align:right;"><button class="btn-action btn-warning" style="padding:6px; width:auto;" onclick="SysEstoque.edit(${p.id})">✏️</button> <button class="btn-action btn-danger" style="padding:6px; width:auto;" onclick="SysEstoque.delete(${p.id})">❌</button></td></tr>`; }); },
            saveProduct: () => { const id = document.getElementById('estEditId').value, n = document.getElementById('estNome').value, p = parseFloat(document.getElementById('estPreco').value), s = parseInt(document.getElementById('estQtd').value); if(!n || isNaN(p) || isNaN(s)) return SysToast.show('Preencha os campos.', 'error'); let prods = SysDB.get('Products'); if(id) { const i = prods.findIndex(x => x.id == id); if(i > -1) prods[i] = { id: parseInt(id), name: n, price: p, stock: s }; } else prods.push({ id: Date.now(), name: n, price: p, stock: s }); SysDB.set('Products', prods); SysEstoque.clearForm(); SysEstoque.render(); SysToast.show("Estoque atualizado.", "success"); },
            edit: (id) => { const p = SysDB.get('Products').find(x => x.id === id); if(p) { document.getElementById('estEditId').value = p.id; document.getElementById('estNome').value = p.name; document.getElementById('estPreco').value = p.price; document.getElementById('estQtd').value = p.stock; document.getElementById('btnSalvarEstoque').innerText = "Confirmar Alteração"; } },
            delete: (id) => { SysDB.set('Products', SysDB.get('Products').filter(x => x.id !== id)); SysEstoque.render(); SysToast.show("Produto excluído.", "success"); },
            clearForm: () => { document.getElementById('estEditId').value = ''; document.getElementById('estNome').value = ''; document.getElementById('estPreco').value = ''; document.getElementById('estQtd').value = ''; document.getElementById('btnSalvarEstoque').innerText = "Proteger Estoque"; }
        };

        const SysAuth = {
            login: () => { const u = document.getElementById('loginUser').value, p = document.getElementById('loginPass').value, authUser = SysDB.get('Users').find(x => x.user === u && x.pass === p); if(authUser) { sessionStorage.setItem('BF_User', authUser.user); sessionStorage.setItem('BF_Role', authUser.role); SysLog.add(`Login efetuado: ${authUser.user}`); SysAuth.grantAccess(); } else { SysToast.show('Acesso negado. Verifique suas credenciais.', 'error'); } },
            logout: () => { sessionStorage.clear(); location.reload(); },
            grantAccess: () => { 
                document.getElementById('loginScreen').style.display = 'none'; document.getElementById('mainApp').style.display = 'flex'; 
                const userName = sessionStorage.getItem('BF_User'); const isLeandro = userName.toLowerCase().includes('leandro'); document.getElementById('loggedUserName').innerText = isLeandro ? `Comandante Leandro` : userName;
                if(sessionStorage.getItem('BF_Role') === 'ADMIN') document.body.classList.add('is-admin'); else document.body.classList.remove('is-admin'); 
                SysSecurity.checkLock(); SysPDV.loadDependencies(); SysClientes.render(); SysFiscal.checkAccountingDates(); SysSync.startWorker(); SysToast.show(`Autenticação confirmada. Bom trabalho!`, 'success');
            }
        };

        const SysSecurity = {
            checkLock: () => { const status = SysDB.get('License'), role = sessionStorage.getItem('BF_Role'), overlay = document.getElementById('pdvLockOverlay'); if(role === 'ADMIN') overlay.style.display = 'none'; else overlay.style.display = status === 'unlocked' ? 'none' : 'flex'; },
            generateKey: () => { let doc = document.getElementById('genDocInput').value.replace(/\D/g, ''); if(doc.length < 11) return SysToast.show("Documento curto.", "error"); const fixedCnpj = 59365037000166n; const numPart = (fixedCnpj + BigInt(doc)).toString().padStart(11, '0').slice(-11); let rl = ""; for(let i=0; i<4; i++) rl += "ABCDEFGHIJKLMNOPQRSTUVWXYZ".charAt(Math.floor(Math.random() * 26)); document.getElementById('generatedKey').value = numPart + rl; SysToast.show("Hash de licença computado.", "success"); },
            forceUnlock: () => { SysDB.set('License', 'unlocked'); SysSecurity.checkLock(); SysToast.show("Caixas liberados para operação.", "success"); },
            forceLock: () => { SysDB.set('License', 'locked'); SysSecurity.checkLock(); SysToast.show("Kill Switch acionado. Caixas paralisados.", "error"); },
            validateLicense: () => { const doc = document.getElementById('opDocInput').value.replace(/\D/g, ''), key = document.getElementById('opKeyInput').value.trim(); if(doc.length >= 11 && key.length === 15 && /[A-Z]{4}$/.test(key)) { SysDB.set('License', 'unlocked'); SysSecurity.checkLock(); SysToast.show("Operação restaurada.", "success"); } else { SysToast.show("Serial de desbloqueio inválido.", "error"); } }
        };

        const SysConfig = {
            loadParams: () => { const cfg = SysDB.get('Config'); document.getElementById('cfgPixKey').value = cfg.pixKey || ''; document.getElementById('cfgTaxa').value = cfg.taxaEntrega; document.getElementById('cfgDdns').value = cfg.ddns; document.getElementById('cfgEmailContador').value = cfg.emailContador || ''; document.getElementById('cfgInterRef').value = cfg.interRefLink || ''; SysConfig.renderUsers(); SysConfig.renderMotoboys(); },
            saveParams: () => { const cfg = SysDB.get('Config'); cfg.pixKey = document.getElementById('cfgPixKey').value; cfg.taxaEntrega = parseFloat(document.getElementById('cfgTaxa').value); cfg.ddns = document.getElementById('cfgDdns').value; cfg.interRefLink = document.getElementById('cfgInterRef').value; SysDB.set('Config', cfg); SysToast.show("Parâmetros operacionais gravados.", "success"); SysPDV.loadDependencies(); },
            renderUsers: () => { const tbody = document.querySelector('#tblUsers tbody'); tbody.innerHTML = ''; SysDB.get('Users').forEach(u => { tbody.innerHTML += `<tr><td style="color:#aaa;">${u.user}</td><td style="text-align:right;"><button class="btn-action btn-warning" style="padding:4px 8px; width:auto; font-size:0.8rem;" onclick="SysConfig.editUser(${u.id})">Nova Senha</button> ${u.user !== 'leandro' ? `<button class="btn-action btn-danger" style="padding:4px 8px; width:auto; font-size:0.8rem;" onclick="SysConfig.delUser(${u.id})">Deletar</button>` : ''}</td></tr>`; }); },
            addUser: () => { const u = prompt("ID do Operador:"); if(!u) return; const p = prompt("Senha de Acesso:"); if(!p) return; let users = SysDB.get('Users'); users.push({ id: Date.now(), user: u, pass: p, role: 'OPERADOR' }); SysDB.set('Users', users); SysConfig.renderUsers(); SysToast.show("Novo operador autorizado.", "success"); },
            editUser: (id) => { let users = SysDB.get('Users'); const i = users.findIndex(x => x.id === id); if(i > -1) { const np = prompt("Nova credencial secreta:"); if(np) { users[i].pass = np; SysDB.set('Users', users); SysToast.show("Credencial atualizada.", "success"); } } },
            delUser: (id) => { SysDB.set('Users', SysDB.get('Users').filter(x => x.id !== id)); SysConfig.renderUsers(); SysToast.show("Operador descredenciado.", "success"); },
            renderMotoboys: () => { const tbody = document.querySelector('#tblMotoboys tbody'); tbody.innerHTML = ''; SysDB.get('Motoboys').forEach(m => { tbody.innerHTML += `<tr><td style="color:var(--neon-blue); font-weight:bold;">${m.name}</td><td style="text-align:right;"><button class="btn-action btn-danger" style="padding:4px 8px; width:auto; font-size:0.8rem;" onclick="SysConfig.delMotoboy(${m.id})">Desvincular</button></td></tr>`; }); },
            addMotoboy: () => { const n = prompt("Identificação do Entregador:"); if(n) { let m = SysDB.get('Motoboys'); m.push({ id: Date.now(), name: n }); SysDB.set('Motoboys', m); SysConfig.renderMotoboys(); SysToast.show("Frota logística expandida.", "success"); } },
            delMotoboy: (id) => { SysDB.set('Motoboys', SysDB.get('Motoboys').filter(x => x.id !== id)); SysConfig.renderMotoboys(); SysToast.show("Entregador desligado.", "success"); },
            resetDatabase: () => { if(confirm("ALERTA CRÍTICO: Formatação física (IndexedDB) irá apagar toda a base. Prossiga com cautela. Confirmar wipe?")) { const req = indexedDB.deleteDatabase("BigFood_OS_Database"); req.onsuccess = () => { sessionStorage.clear(); location.reload(); }; } }
        };

        const SysUI = { switchTab: (tabId, btn) => { document.querySelectorAll('.panel, .btn-nav').forEach(e => e.classList.remove('active')); document.getElementById(tabId).classList.add('active'); btn.classList.add('active'); if(tabId==='tab-estoque')SysEstoque.render(); if(tabId==='tab-clientes')SysClientes.render(); if(tabId==='tab-pdv')SysPDV.loadDependencies(); if(tabId==='tab-financeiro')SysFinanceiro.render(); if(tabId==='tab-config')SysConfig.loadParams(); } };

        // === PDV CORE & POLLING MOCK ===
        let cart = []; let currentPixStr = ""; let pollingInterval = null;
        const SysPDV = {
            loadDependencies: () => {
                const s = document.getElementById('pdvProdutoSelect'); s.innerHTML = ''; SysDB.get('Products').forEach(p => { s.innerHTML += `<option value="${p.id}">${p.name} - R$ ${p.price.toFixed(2)}</option>`; });
                const cfg = SysDB.get('Config');
                const m = document.getElementById('pdvMotoboy'); m.innerHTML = `<option value="0">Retirada Local (R$ 0,00)</option>`; SysDB.get('Motoboys').forEach(mb => { m.innerHTML += `<option value="${cfg.taxaEntrega}">Rota: ${mb.name} (+ R$ ${cfg.taxaEntrega.toFixed(2)})</option>`; });
                const c = document.getElementById('pdvClienteSelect'); c.innerHTML = `<option value="0">Cliente Avulso (Não Registrado)</option>`; SysDB.get('Customers').forEach(cli => { c.innerHTML += `<option value="${cli.id}">${cli.name} - CPF/CNPJ: ${cli.doc}</option>`; });
                
                // Toggle do botão de Afiliado (Se tiver link configurado, ele habilita a função)
                document.getElementById('btnAffiliate').style.display = cfg.interRefLink ? 'block' : 'none';
                SysPDV.updateTotal();
            },
            addItem: () => { if(sessionStorage.getItem('BF_Role') !== 'ADMIN' && SysDB.get('License') !== 'unlocked') return; const id = parseInt(document.getElementById('pdvProdutoSelect').value), qtd = parseInt(document.getElementById('pdvQtd').value), prod = SysDB.get('Products').find(p => p.id === id); if(prod && prod.stock >= qtd) { cart.push({ ...prod, cartQtd: qtd }); SysPDV.renderCart(); } else { SysToast.show('Falta de suprimento no inventário físico.', 'error'); } },
            renderCart: () => { const tbody = document.querySelector('#pdvCartTable tbody'); tbody.innerHTML = ''; cart.forEach((i, idx) => { tbody.innerHTML += `<tr><td><strong>${i.name}</strong></td><td>${i.cartQtd}</td><td style="color:var(--success);">R$ ${(i.price * i.cartQtd).toFixed(2)}</td><td style="text-align:center;"><button class="btn-action btn-danger" style="height:auto; padding: 4px 10px;" onclick="SysPDV.removeItem(${idx})">Remover</button></td></tr>`; }); SysPDV.updateTotal(); },
            removeItem: (idx) => { cart.splice(idx, 1); SysPDV.renderCart(); },
            updateTotal: () => { let t = 0; cart.forEach(i => t += (i.price * i.cartQtd)); t += parseFloat(document.getElementById('pdvMotoboy').value || 0); document.getElementById('pdvTotal').innerText = t.toFixed(2); },
            
            // FUNÇÃO DE MARKETING DE AFILIADO
            sendInterInvite: () => {
                const cfg = SysDB.get('Config');
                const cliId = parseInt(document.getElementById('pdvClienteSelect').value); 
                let clienteVenda = SysDB.get('Customers').find(x => x.id === cliId);
                
                if(!clienteVenda || !clienteVenda.phone) {
                    SysToast.show("Selecione um cliente com WhatsApp cadastrado.", "warning");
                    return;
                }
                
                const foneNum = clienteVenda.phone.replace(/\D/g, '');
                const msg = `Olá ${clienteVenda.name}, vi que você não usa o Pix. Abra sua conta no Banco Inter pelo meu convite e ganhe benefícios exclusivos! Acesse aqui: ${cfg.interRefLink}`;
                window.open(`https://wa.me/55${foneNum}?text=${encodeURIComponent(msg)}`, '_blank');
                SysToast.show("Link de indicação Banco Inter enviado!", "inter");
            },

            generatePix: () => {
                const cfg = SysDB.get('Config'); if(!cfg.pixKey) return SysToast.show("Configure a Chave PIX do Inter no Admin.", "warning"); if(cart.length === 0) return SysToast.show("Carrinho vazio.", "warning");
                currentPixStr = `00020101021226580014br.gov.bcb.pix0136${cfg.pixKey}5204000053039865405${document.getElementById('pdvTotal').innerText}5802BR5913BigFood6009Guarulhos62070503***6304ABCD`;
                document.getElementById('pixPayload').innerText = currentPixStr;
                const qrImg = document.getElementById('pixQrImage'); qrImg.src = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${encodeURIComponent(currentPixStr)}`; qrImg.style.display = 'block';
                
                SysToast.show("Arranjo PIX Inter pronto para captura.", "inter");

                // MOCK DE POLLING (Simulando a escuta do servidor C#)
                const paymentBox = document.getElementById('paymentBox');
                paymentBox.classList.add('scanning');
                document.getElementById('syncStatus').innerText = `📡 Escutando Safenode (${cfg.ddns}) por Webhooks do Inter...`;
                
                // Habilita o botão manual para testes, mas visualmente mostra que está automático
                const btnSync = document.getElementById('btnSync');
                btnSync.disabled = false;
                btnSync.style.background = 'linear-gradient(135deg, #00b09b, #96c93d)';
                btnSync.style.color = '#000';
            },

            finalizeOrder: async () => {
                if(cart.length === 0) return SysToast.show("Nenhum item processado.", "warning");
                const cliId = parseInt(document.getElementById('pdvClienteSelect').value); let clienteVenda = SysDB.get('Customers').find(x => x.id === cliId); let docNota = clienteVenda ? clienteVenda.doc : "";
                
                const respDoc = await SysModal.open("Nota Fiscal Paulista", docNota);
                if(respDoc !== null && respDoc.trim() !== "") { if(!clienteVenda) clienteVenda = { name: "Consumidor Local", doc: respDoc, address: "" }; else clienteVenda.doc = respDoc; }

                const paymentBox = document.getElementById('paymentBox');
                paymentBox.classList.remove('scanning');
                const btn = document.getElementById('btnSync'); btn.innerText = "Empacotando Remessa..."; btn.disabled = true;

                setTimeout(() => {
                    let p = SysDB.get('Products'), t = parseFloat(document.getElementById('pdvTotal').innerText);
                    cart.forEach(c => { let pr = p.find(x => x.id === c.id); if(pr) pr.stock -= c.cartQtd; }); SysDB.set('Products', p);
                    let s = SysDB.get('Sales'); s.push({ t, date: new Date().toLocaleString() }); SysDB.set('Sales', s);
                    
                    const motoName = document.getElementById('pdvMotoboy').options[document.getElementById('pdvMotoboy').selectedIndex].text;
                    const cfg = SysDB.get('Config');
                    if(!currentPixStr) currentPixStr = `00020101021226580014br.gov.bcb.pix0136${cfg.pixKey}5204000053039865405${t}5802BR5913BigFood6009Guarulhos62070503***6304ABCD`;
                    
                    const chaveAcesso = SysFiscal.gerarChaveAcesso();
                    const payloadIntegracao = SysFiscal.generateNfcePayload(cart, t, clienteVenda, chaveAcesso); 
                    SysDB.addToSyncQueue(payloadIntegracao);

                    SysPDV.printThermalReceipt(cart, t, motoName, 'Banco Inter', cfg.pixKey, currentPixStr, clienteVenda, chaveAcesso);
                    SysLog.add(`Transação PIX aprovada pelo Banco Inter. R$ ${t.toFixed(2)}`);
                    
                    cart = []; currentPixStr = ""; document.getElementById('pixQrImage').style.display = 'none'; SysPDV.renderCart(); 
                    document.getElementById('pixPayload').innerText = "Aguardando gatilho...";
                    document.getElementById('syncStatus').innerText = "";
                    btn.innerText = "2. CONFIRMAR RECEBIMENTO"; btn.style.background = '#333'; btn.style.color = '#888';
                    SysToast.show("Transação aprovada pelo servidor. Caixa finalizado.", "success");
                }, 800);
            },
            printThermalReceipt: (cItems, t, motoName, banco, pKey, pixStr, cliente, chaveAcesso) => {
                const qrNfceUrl = `https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=https://www.sefaz.sp.gov.br/nfce/consulta?p=${chaveAcesso}`;
                const qrPixUrl = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=${encodeURIComponent(pixStr)}`;
                let clienteHtml = `<div class="fiscal-box"><strong>CONSUMIDOR OMITIDO</strong></div>`;
                if(cliente) clienteHtml = `<div class="fiscal-box"><strong>DADOS DO CONSUMIDOR</strong><br>Nome: ${cliente.name}<br>Doc Fiscal: ${cliente.doc}<br>End: ${cliente.address || ''}</div>`;
                document.getElementById('printReceipt').innerHTML = `<h1 class="print-title">BIGFOOD PDV - GUARULHOS</h1><p style="text-align:center; margin:0;">CUPOM AUXILIAR NFCe</p><hr style="border: 1px dashed #000; margin: 5px 0;">${cItems.map(i => `<div class="item-linha"><span>${i.cartQtd}x ${i.name.substring(0,15)}</span><span>R$ ${(i.price*i.cartQtd).toFixed(2)}</span></div>`).join('')}<div class="item-linha" style="margin-top:5px;"><span>${motoName}</span></div><div class="total-linha">TOTAL LIQUIDADO: R$ ${t.toFixed(2)}</div>${clienteHtml}<div class="fiscal-box"><strong>CHAVE ESTADUAL DE ACESSO</strong><br>${chaveAcesso.match(/.{1,4}/g).join(' ')}<br><img src="${qrNfceUrl}" class="qr-print-img"><p style="margin:2px 0;">Acesse via app Sefaz</p></div><div class="fiscal-box"><strong>QR CODE PIX (PAGAMENTO)</strong><br>Instituição: ${banco} | Chave: ${pKey}<br><img src="${qrPixUrl}" class="qr-print-img"></div><p style="text-align: center; margin-top: 10px; font-weight:bold;">Operador: ${sessionStorage.getItem('BF_User')}<br>${new Date().toLocaleString()}</p>`;
                window.print();
            }
        };

        const SysFinanceiro = { render: () => { const sales = SysDB.get('Sales'); let t = 0; sales.forEach(s => t += s.t); document.getElementById('finTotalVendas').innerText = t.toFixed(2); document.getElementById('finTotalPedidos').innerText = sales.length; document.getElementById('finPayout').innerText = (sales.length * SysDB.get('Config').taxaEntrega).toFixed(2); } };

        window.onload = async () => { await SysDB.initIDB(); if(sessionStorage.getItem('BF_Role')) SysAuth.grantAccess(); };
    </script>
</body>
</html>
